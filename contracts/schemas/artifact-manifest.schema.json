{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "weave-v5/artifact-manifest/v1",
  "type": "object",
  "required": ["schema", "sealed_at", "file_count", "files"],
  "properties": {
    "schema":     { "type": "string" },
    "sealed_at":  { "type": "string", "format": "date-time" },
    "file_count": { "type": "integer", "minimum": 0 },
    "app_id":     { "type": "string" },
    "git_sha":    { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path":   { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
