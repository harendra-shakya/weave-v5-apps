{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "weave-v5/catalog/v1",
  "description": "A single catalog item available for purchase in any storefront.",
  "type": "object",
  "required": ["id", "title", "price_cents", "currency", "category"],
  "properties": {
    "id":          { "type": "string", "minLength": 1 },
    "title":       { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "price_cents": { "type": "integer", "minimum": 0 },
    "currency":    { "type": "string", "enum": ["USD"] },
    "category":    { "type": "string", "minLength": 1 },
    "creator":     { "type": "string" },
    "media_ref":   { "type": "string", "description": "Path or placeholder ref — no real external URLs" },
    "metadata":    { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
